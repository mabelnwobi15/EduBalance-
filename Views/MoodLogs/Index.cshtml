@model IEnumerable<EduBalance.Models.MoodLog>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            
            <th>
                @Html.DisplayNameFor(model => model.MoodType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateLogged)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
          
            <td>
                @Html.DisplayFor(modelItem => item.MoodType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Notes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateLogged)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MoodLogId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MoodLogId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MoodLogId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
