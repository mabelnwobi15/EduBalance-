@model EduBalance.Models.MoodLog

@{
    ViewData["Title"] = "Log Mood";
}

<div class="balance-page"> <!-- Reuse your existing CSS classes -->
    <div class="balance-card">
        <h2 class="balance-title">How are you feeling?</h2>
        <p class="balance-subtitle">Capture your current emotional state.</p>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="field-block">
                <label class="fw-bold mb-2">Mood Type</label>
                <!-- Replacing the text box with a dropdown makes it much cleaner -->
                <select asp-for="MoodType" class="field-input">
                    <option value="">Select a mood...</option>
                    <option value="Happy">😊 Happy</option>
                    <option value="Focused">🧠 Focused</option>
                    <option value="Stressed">😫 Stressed</option>
                    <option value="Tired">😴 Tired</option>
                    <option value="Anxious">😰 Anxious</option>
                </select>
                <span asp-validation-for="MoodType" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label asp-for="Notes" class="fw-bold mb-2">Notes (Optional)</label>
                <textarea asp-for="Notes" class="field-input" rows="3" placeholder="What's on your mind?"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="action-row">
                <a asp-action="Index" class="btn-soft">View History</a>
                <button type="submit" class="btn-main">Save Mood</button>
            </div>
        </form>
    </div>
</div>