@model EduBalance.Models.MoodLog

@{
    ViewData["Title"] = "Delete Mood Log";
}

<style>
    body {
        background: #fff7f7;
        font-family: 'Segoe UI', sans-serif;
    }

    .delete-container {
        max-width: 650px;
        margin: 60px auto;
    }

    .delete-card {
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(220,38,38,0.08);
    }

    .title {
        color: #dc2626;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .warning {
        color: #6b7280;
        margin-bottom: 30px;
    }

    .detail-box {
        margin-bottom: 20px;
    }

    .label {
        font-weight: 700;
        color: #dc2626;
    }

    .btn-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .delete-btn {
        background: #dc2626;
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 12px;
        font-weight: 700;
    }

    .cancel-btn {
        background: #e5e7eb;
        color: #111827;
        padding: 12px 22px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
    }
</style>

<div class="delete-container">

    <div class="delete-card">

        <div class="title">Delete Mood Log</div>

        <div class="warning">
            Are you sure you want to delete this mood log?
        </div>

        <div class="detail-box">
            <div class="label">Mood</div>
            <div>@Model.MoodType</div>
        </div>

        <div class="detail-box">
            <div class="label">Notes</div>
            <div>@Model.Notes</div>
        </div>

        <form asp-action="Delete">

            <input type="hidden" asp-for="MoodLogId" />

            <div class="btn-group">

                <button type="submit" class="delete-btn">
                    Delete
                </button>

                <a asp-action="Index" class="cancel-btn">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>