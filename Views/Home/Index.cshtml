@{
    ViewData["Title"] = "EduBalance Dashboard";
}

<style>
    :root {
        --primary-green: #2fbf71;
        --secondary-green: #24a861;
        --light-green: #ecfff4;
        --soft-bg: #f4fff8;
        --text-dark: #1f2937;
        --text-light: #6b7280;
        --white: #ffffff;
        --danger: #dc2626;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: var(--soft-bg);
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden;
    }

    .dashboard-layout {
        display: flex;
        min-height: 100vh;
    }

    /* SIDEBAR */
    .sidebar {
        width: 280px;
        background: white;
        padding: 30px 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        position: fixed;
        height: 100vh;
        overflow-y: auto;
    }

    .logo-section {
        text-align: center;
        margin-bottom: 40px;
    }

    .logo-section img {
        width: 90px;
        margin-bottom: 15px;
    }

    .logo-title {
        font-size: 2rem;
        font-weight: 800;
        color: var(--secondary-green);
    }

    .logo-subtitle {
        color: var(--text-light);
        font-size: 0.95rem;
        margin-top: 5px;
    }

    .menu-title {
        color: var(--secondary-green);
        font-size: 0.9rem;
        font-weight: 800;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .sidebar-menu {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .menu-link {
        display: flex;
        align-items: center;
        gap: 15px;
        text-decoration: none;
        padding: 16px;
        border-radius: 18px;
        color: var(--text-dark);
        font-weight: 700;
        transition: 0.3s ease;
    }

    .menu-link:hover {
        background: var(--light-green);
        transform: translateX(5px);
        color: var(--secondary-green);
    }

    .menu-link.active {
        background: linear-gradient(135deg, var(--primary-green), var(--secondary-green));
        color: white;
        box-shadow: 0 10px 25px rgba(47,191,113,0.2);
    }

    .menu-icon {
        font-size: 1.4rem;
    }

    /* MAIN CONTENT */
    .main-content {
        margin-left: 280px;
        flex: 1;
        padding: 40px;
    }

    .hero-card {
        background: linear-gradient(135deg, var(--primary-green), var(--secondary-green));
        border-radius: 30px;
        padding: 45px;
        color: white;
        margin-bottom: 35px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(47,191,113,0.25);
    }

    .hero-card::before {
        content: "";
        position: absolute;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        top: -70px;
        right: -70px;
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .hero-text {
        max-width: 700px;
        line-height: 1.8;
        font-size: 1.1rem;
    }

    /* STATS */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 35px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.04);
        transition: 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }

    .stat-icon {
        font-size: 2rem;
        margin-bottom: 15px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--secondary-green);
    }

    .stat-label {
        color: var(--text-light);
        margin-top: 5px;
    }

    /* CHARTS */
    .chart-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
        margin-bottom: 35px;
    }

    .chart-card {
        background: white;
        border-radius: 25px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .chart-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--secondary-green);
        margin-bottom: 20px;
    }

    canvas {
        width: 100% !important;
        height: 300px !important;
    }

    /* QUICK ACTIONS */
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .action-card {
        background: white;
        border-radius: 24px;
        padding: 30px;
        text-decoration: none;
        color: inherit;
        box-shadow: 0 10px 25px rgba(0,0,0,0.04);
        transition: 0.3s ease;
        border: 1px solid rgba(47,191,113,0.08);
    }

    .action-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 18px 35px rgba(47,191,113,0.15);
    }

    .action-icon {
        font-size: 2.5rem;
        margin-bottom: 15px;
    }

    .action-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--secondary-green);
        margin-bottom: 10px;
    }

    .action-text {
        color: var(--text-light);
        line-height: 1.7;
    }

    /* RESPONSIVE */
    @@media(max-width:1200px){

        .stats-grid,
        .quick-actions {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:900px){

        .sidebar {
            display: none;
        }

        .main-content {
            margin-left: 0;
            padding: 20px;
        }

        .chart-grid,
        .stats-grid,
        .quick-actions {
            grid-template-columns: 1fr;
        }

        .hero-title {
            font-size: 2rem;
        }
    }
</style>

<div class="dashboard-layout">

    <!-- SIDEBAR -->
    <div class="sidebar">

        <div class="logo-section">

            <img src="~/images/edubalance-logo.png"
                 alt="EduBalance Logo" />

            <div class="logo-title">
                EduBalance
            </div>

            <div class="logo-subtitle">
                Wellness & Study Platform
            </div>

        </div>

        <div class="menu-title">
            Main Menu
        </div>

        <div class="sidebar-menu">

            <a asp-controller="Home"
               asp-action="Index"
               class="menu-link active">

                <div class="menu-icon">🏠</div>
                <div>Dashboard</div>

            </a>

            <a asp-controller="MoodLogs"
               asp-action="Index"
               class="menu-link">

                <div class="menu-icon">😊</div>
                <div>Mood Logs</div>

            </a>

            <a asp-controller="Schedules"
               asp-action="Index"
               class="menu-link">

                <div class="menu-icon">📅</div>
                <div>Schedules</div>

            </a>

            <a asp-controller="StressCheckIn"
               asp-action="Index"
               class="menu-link">

                <div class="menu-icon">🧠</div>
                <div>Stress Check-In</div>

            </a>

            <a asp-controller="StudyBalances"
               asp-action="Index"
               class="menu-link">

                <div class="menu-icon">⚖️</div>
                <div>Study Balance</div>

            </a>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- HERO -->
        <div class="hero-card">

            <h1 class="hero-title">
                Balance Your Wellness & Academics
            </h1>

            <p class="hero-text">
                EduBalance helps students manage emotional wellness,
                monitor stress, organize schedules, and maintain healthy
                study habits through a supportive digital experience.
            </p>

        </div>

        <!-- STATS -->
        <div class="stats-grid">

            <div class="stat-card">
                <div class="stat-icon">😊</div>
                <div class="stat-value" id="moodCount">0</div>
                <div class="stat-label">Mood Logs</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">🧠</div>
                <div class="stat-value" id="stressCount">0</div>
                <div class="stat-label">Stress Check-Ins</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">📚</div>
                <div class="stat-value" id="studyHours">0</div>
                <div class="stat-label">Study Hours</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">⚖️</div>
                <div class="stat-value" id="balanceScore">0%</div>
                <div class="stat-label">Balance Score</div>
            </div>

        </div>

        <!-- CHARTS -->
        <div class="chart-grid">

            <div class="chart-card">

                <div class="chart-title">
                    Weekly Mood Overview
                </div>

                <canvas id="moodChart"></canvas>

            </div>

            <div class="chart-card">

                <div class="chart-title">
                    Study vs Break Balance
                </div>

                <canvas id="studyChart"></canvas>

            </div>

        </div>

        <!-- QUICK ACTIONS -->
        <div class="quick-actions">

            <a asp-controller="MoodLogs"
               asp-action="Create"
               class="action-card">

                <div class="action-icon">😊</div>

                <div class="action-title">
                    Log Mood
                </div>

                <div class="action-text">
                    Reflect on your emotions and wellbeing.
                </div>

            </a>

            <a asp-controller="StressCheckIn"
               asp-action="Create"
               class="action-card">

                <div class="action-icon">🧠</div>

                <div class="action-title">
                    Stress Check-In
                </div>

                <div class="action-text">
                    Track stress levels and emotional triggers.
                </div>

            </a>

            <a asp-controller="Schedules"
               asp-action="Create"
               class="action-card">

                <div class="action-icon">📅</div>

                <div class="action-title">
                    Add Schedule
                </div>

                <div class="action-text">
                    Organize study sessions and tasks.
                </div>

            </a>

            <a asp-controller="StudyBalances"
               asp-action="Create"
               class="action-card">

                <div class="action-icon">⚖️</div>

                <div class="action-title">
                    Study Balance
                </div>

                <div class="action-text">
                    Balance study time with healthy breaks.
                </div>

            </a>

        </div>

    </div>

</div>

<!-- CHART JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    // Animated Counter
    function animateValue(id, start, end, duration) {

        let range = end - start;
        let current = start;
        let increment = end > start ? 1 : -1;
        let stepTime = Math.abs(Math.floor(duration / range));

        let obj = document.getElementById(id);

        let timer = setInterval(function () {

            current += increment;
            obj.innerHTML = id === "balanceScore"
                ? current + "%"
                : current;

            if (current == end) {
                clearInterval(timer);
            }

        }, stepTime);
    }

    animateValue("moodCount", 0, 24, 1200);
    animateValue("stressCount", 0, 12, 1200);
    animateValue("studyHours", 0, 48, 1200);
    animateValue("balanceScore", 0, 86, 1200);

    // Mood Chart
    const moodCtx = document.getElementById('moodChart');

    new Chart(moodCtx, {
        type: 'line',
        data: {
            labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
            datasets: [{
                label: 'Mood Level',
                data: [7, 8, 6, 9, 7, 8, 10],
                borderColor: '#2fbf71',
                backgroundColor: 'rgba(47,191,113,0.15)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            animation: {
                duration: 2000
            }
        }
    });

    // Study Balance Chart
    const studyCtx = document.getElementById('studyChart');

    new Chart(studyCtx, {
        type: 'doughnut',
        data: {
            labels: ['Study Hours', 'Break Hours'],
            datasets: [{
                data: [70, 30],
                backgroundColor: [
                    '#2fbf71',
                    '#b6f0cb'
                ]
            }]
        },
        options: {
            responsive: true,
            animation: {
                animateRotate: true,
                duration: 2000
            }
        }
    });

</script>

