@model IEnumerable<EduBalance.Models.StudyBalance>

@{
    ViewData["Title"] = "Study Balance";
}

<style>
    :root{
        --primary:#2fbf71;
        --secondary:#24a861;
        --bg:#f4fff8;
    }

    body{
        background:var(--bg);
        font-family:'Segoe UI',sans-serif;
    }

    .balance-page{
        padding:40px;
    }

    .header{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:30px;
    }

    .title{
        font-size:2.5rem;
        font-weight:800;
        color:var(--secondary);
    }

    .subtitle{
        color:#6b7280;
        margin-top:8px;
    }

    .create-btn{
        background:linear-gradient(135deg,var(--primary),var(--secondary));
        color:white;
        padding:12px 22px;
        border-radius:14px;
        text-decoration:none;
        font-weight:700;
        box-shadow:0 10px 25px rgba(47,191,113,0.18);
    }

    .balance-grid{
        display:grid;
        gap:20px;
    }

    .balance-card{
        background:white;
        border-radius:25px;
        padding:25px;
        box-shadow:0 10px 25px rgba(0,0,0,0.05);
        border-left:6px solid var(--primary);
        transition:0.3s ease;
    }

    .balance-card:hover{
        transform:translateY(-4px);
    }

    .top{
        display:flex;
        justify-content:space-between;
        margin-bottom:20px;
    }

    .date{
        color:#6b7280;
    }

    .ratio{
        font-size:1.4rem;
        font-weight:800;
        color:var(--secondary);
    }

    .stats{
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:20px;
        margin-bottom:20px;
    }

    .stat-box{
        background:#ecfff4;
        border-radius:18px;
        padding:20px;
        text-align:center;
    }

    .stat-number{
        font-size:2rem;
        font-weight:800;
        color:var(--secondary);
    }

    .stat-label{
        color:#6b7280;
        margin-top:5px;
    }

    .actions{
        display:flex;
        gap:12px;
    }

    .btn-action{
        padding:10px 16px;
        border-radius:12px;
        text-decoration:none;
        font-weight:700;
    }

    .details-btn{
        background:#dff8ea;
        color:var(--secondary);
    }

    .delete-btn{
        background:#ffe7e7;
        color:#dc2626;
    }
</style>

<div class="balance-page">

    <div class="header">

        <div>

            <div class="title">⚖️ Study Balance</div>

            <div class="subtitle">
                Maintain a healthy balance between studying and resting.
            </div>

        </div>

        <a asp-action="Create" class="create-btn">
            + Add Balance
        </a>

    </div>

    <div class="balance-grid">

        @foreach(var item in Model)
        {
            <div class="balance-card">

                <div class="top">

                    <div class="ratio">
                        Study vs Break Balance
                    </div>

                    <div class="date">
                        @item.DateRecorded.ToString("dd MMM yyyy")
                    </div>

                </div>

                <div class="stats">

                    <div class="stat-box">

                        <div class="stat-number">
                            @item.StudyHours
                        </div>

                        <div class="stat-label">
                            Study Hours
                        </div>

                    </div>

                    <div class="stat-box">

                        <div class="stat-number">
                            @item.BreakHours
                        </div>

                        <div class="stat-label">
                            Break Hours
                        </div>

                    </div>

                </div>

                <div class="actions">

                    <a asp-action="Details"
                       asp-route-id="@item.StudyBalanceId"
                       class="btn-action details-btn">
                        Details
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.StudyBalanceId"
                       class="btn-action delete-btn">
                        Delete
                    </a>

                </div>

            </div>
        }

    </div>

</div>