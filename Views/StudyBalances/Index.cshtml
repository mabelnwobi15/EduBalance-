@model IEnumerable<EduBalance.Models.StudyBalance>

@{
    ViewData["Title"] = "Study Balance Logs";
}

<div class="card p-4 shadow-sm rounded-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Study Balance Logs</h2>
        <a asp-action="Create" class="btn btn-primary">Add New</a>
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Study Hours</th>
                <th>Break Hours</th>
                <th>Date Recorded</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.StudyHours</td>
                    <td>@item.BreakHours</td>
                    <td>@item.DateRecorded.ToString("dd MMM yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>