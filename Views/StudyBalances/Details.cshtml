@model EduBalance.Models.StudyBalance

@{
    ViewData["Title"] = "Study Balance Details";
}

<style>
    body{
        background:#f4fff8;
        font-family:'Segoe UI',sans-serif;
    }

    .details-page{
        max-width:700px;
        margin:50px auto;
    }

    .card{
        background:white;
        border-radius:25px;
        padding:40px;
        box-shadow:0 10px 30px rgba(0,0,0,0.05);
    }

    .title{
        font-size:2rem;
        font-weight:800;
        color:#24a861;
        margin-bottom:30px;
    }

    .info{
        margin-bottom:25px;
    }

    .label{
        font-weight:800;
        color:#24a861;
    }

    .value{
        margin-top:5px;
        color:#374151;
    }

    .back-btn{
        display:inline-block;
        margin-top:20px;
        background:#2fbf71;
        color:white;
        padding:12px 20px;
        border-radius:12px;
        text-decoration:none;
        font-weight:700;
    }
</style>

<div class="details-page">

    <div class="card">

        <div class="title">⚖️ Study Balance Details</div>

        <div class="info">

            <div class="label">Study Hours</div>

            <div class="value">
                @Model.StudyHours Hours
            </div>

        </div>

        <div class="info">

            <div class="label">Break Hours</div>

            <div class="value">
                @Model.BreakHours Hours
            </div>

        </div>

        <div class="info">

            <div class="label">Date Recorded</div>

            <div class="value">
                @Model.DateRecorded
            </div>

        </div>

        <a asp-action="Index" class="back-btn">
            Back to History
        </a>

    </div>

</div>